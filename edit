<!DOCTYPE html>
<html>
<head>
  <title>Editar Pichanga</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    /* Reusing your exact same styles for consistency */
    :root {
      --primary: #059669;
      --primary-hover: #047857;
      --bg-overlay: rgba(15, 23, 42, 0.9);
      --bg-card: #ffffff;
      --bg-muted: #f8fafc;
      --border: #e2e8f0;
      --text-main: #1e293b;
      --text-muted: #64748b;
      --shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }
    #pichanga-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: var(--bg-overlay); z-index: 10000;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Inter', sans-serif; box-sizing: border-box; padding: 20px;
      backdrop-filter: blur(4px);
    }
    #pichanga-form {
      background: var(--bg-card); padding: 32px; border-radius: 24px;
      width: 100%; max-width: 440px; display: flex; flex-direction: column;
      gap: 18px; box-shadow: var(--shadow); max-height: 92vh; overflow-y: auto;
    }
    .p-label { font-size: 11px; font-weight: 700; color: var(--text-muted); margin-bottom: 6px; display: block; text-transform: uppercase; }
    .p-input { width: 100%; padding: 12px 16px; border: 1.5px solid var(--border); border-radius: 10px; font-size: 13px; color: var(--text-main); background: var(--bg-muted); outline: none; transition: all 0.2s; }
    .p-input:focus { border-color: var(--primary); background: white; box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.1); }
    .p-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .btn-gen { width: 100%; padding: 16px; border: none; border-radius: 14px; background: var(--primary); color: white; font-weight: 700; cursor: pointer; margin-top: 8px; }
    .btn-cancel { width: 100%; background: none; border: none; color: var(--text-muted); font-size: 14px; cursor: pointer; padding: 8px; text-decoration: underline; }
    .loading-msg { text-align: center; color: var(--primary); font-weight: 600; }
  </style>
</head>
<body>
  <script>
    (async function() {
      const SUPABASE_URL = 'https://fzrpjbojyzzohcypgfzm.supabase.co';
      const SUPABASE_KEY = 'sb_publishable_6WvoLA-b4diZ4_omsc-XUg_5iNrppdz';
      
      // Get ID from URL: editor.html?id=123
      const params = new URLSearchParams(window.location.search);
      const recordId = params.get('id');

      if (!recordId) {
        document.body.innerHTML = '<div id="pichanga-overlay"><div id="pichanga-form"><p class="loading-msg">Error: No se encontró ID de pichanga.</p></div></div>';
        return;
      }

      // 1. Create UI Structure
      const overlay = document.createElement('div'); overlay.id = 'pichanga-overlay';
      const form = document.createElement('div'); form.id = 'pichanga-form';
      form.innerHTML = `<h2 style="margin:0; color:var(--primary); font-size:20px; font-weight:800; text-align:center; margin-bottom:10px;">📝 Editar Pichanga</h2>
                        <p class="loading-msg" id="load-status">Cargando datos...</p>`;
      overlay.appendChild(form);
      document.body.appendChild(overlay);

      const createField = (labelTxt, id, type = 'text') => {
        const div = document.createElement('div');
        div.innerHTML = `<label class="p-label">${labelTxt}</label><input type="${type}" id="${id}" class="p-input">`;
        return div;
      };

      // 2. Fetch Existing Data
      try {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/pichangas?id_pichanga=eq.${recordId}`, {
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` }
        });
        const data = await res.json();
        const pichanga = data[0];

        if (!pichanga) throw new Error("Pichanga no encontrada");

        // Render inputs with existing data
        document.getElementById('load-status').remove();
        
        form.appendChild(createField('Título', 'p-title'));
        form.appendChild(createField('Lugar', 'p-lugar'));
        form.appendChild(createField('Fecha', 'p-date', 'date'));

        const timeRow = document.createElement('div');
        timeRow.className = 'p-two-col';
        timeRow.innerHTML = `<div><label class="p-label">Inicio</label><input type="time" id="p-start" class="p-input"></div>
                             <div><label class="p-label">Fin</label><input type="time" id="p-end" class="p-input"></div>`;
        form.appendChild(timeRow);

        const rowRow = document.createElement('div');
        rowRow.className = 'p-two-col';
        rowRow.appendChild(createField('Cuota', 'p-quota'));
        rowRow.appendChild(createField('N° Jugadores', 'p-count', 'number'));
        form.appendChild(rowRow);

        // Fill values
        document.getElementById('p-title').value = pichanga.titulo;
        document.getElementById('p-lugar').value = pichanga.lugar || '';
        document.getElementById('p-date').value = pichanga.fecha_pichanga;
        document.getElementById('p-start').value = pichanga.hora_inicio;
        document.getElementById('p-end').value = pichanga.hora_fin;
        document.getElementById('p-quota').value = pichanga.cuota.toFixed(2);
        document.getElementById('p-count').value = pichanga.cantidad;

        // Buttons
        const btnSave = document.createElement('button');
        btnSave.textContent = 'Guardar Cambios';
        btnSave.className = 'btn-gen';
        
        const btnCancel = document.createElement('button');
        btnCancel.textContent = 'Cancelar';
        btnCancel.className = 'btn-cancel';
        btnCancel.onclick = () => window.history.back();

        form.append(btnSave, btnCancel);

        // 3. Update Logic
        btnSave.onclick = async () => {
          btnSave.disabled = true;
          btnSave.textContent = 'Guardando...';

          const updateData = {
            titulo: document.getElementById('p-title').value,
            lugar: document.getElementById('p-lugar').value,
            fecha_pichanga: document.getElementById('p-date').value,
            hora_inicio: document.getElementById('p-start').value,
            hora_fin: document.getElementById('p-end').value,
            cuota: parseFloat(document.getElementById('p-quota').value),
            cantidad: parseInt(document.getElementById('p-count').value)
          };

          const patchRes = await fetch(`${SUPABASE_URL}/rest/v1/pichangas?id_pichanga=eq.${recordId}`, {
            method: 'PATCH',
            headers: {
              'apikey': SUPABASE_KEY,
              'Authorization': `Bearer ${SUPABASE_KEY}`,
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(updateData)
          });

          if (patchRes.ok) {
            alert('¡Actualizado correctamente!');
            window.close(); // Or redirect
          } else {
            alert('Error al actualizar');
            btnSave.disabled = false;
            btnSave.textContent = 'Guardar Cambios';
          }
        };

      } catch (err) {
        document.getElementById('load-status').textContent = "Error: " + err.message;
      }
    })();
  </script>
</body>
</html>
